    "axios": "^1.7.7",
    "eslint": "10.2.0",
    "eslint-plugin-vue": "10.8.0",
    "fast-glob": "^3.3.3",
    "lint-staged": "15.4.3",
    "sass": "1.84.0",
    "simple-git-hooks": "2.11.1",
    "tsx": "4.19.2",
