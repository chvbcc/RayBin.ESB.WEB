    "@sa/hooks": "workspace:*",
    "@sa/materials": "workspace:*",
    "@sa/utils": "workspace:*",
    "@vueuse/core": "12.5.0",
    "ant-design-vue": "4.2.6",
    "clipboard": "2.0.11",
    "dayjs": "1.11.20",
